    async def send_meeting_room(self, event) -> str:
        from gateway.platforms.slack_meeting_room import build_meeting_room_blocks, load_store
        channel_id = event.source.chat_id
        store = load_store()
        fallback, blocks = build_meeting_room_blocks(store, channel_id)
        try:
            await self._get_client(channel_id).chat_postEphemeral(
                channel=channel_id, user=event.source.user_id, text=fallback, blocks=blocks)
        except Exception:
            await self._get_client(channel_id).chat_postMessage(channel=channel_id, text=fallback, blocks=blocks)
        return ""

    async def _handle_meeting_slash_background(self, command: dict) -> None:
        try:
            source = self.build_source(
                chat_id=command.get("channel_id", ""),
                chat_type="group",
                user_id=command.get("user_id", ""),
            )
            event = MessageEvent(text="/meeting", message_type=MessageType.COMMAND,
                                 source=source, raw_message=command)
            await self.send_meeting_room(event)
        except Exception as exc:  # pragma: no cover - defensive
            logger.warning("[Slack] meeting room render failed: %s", exc)

    def _meeting_action_lock_key(self, channel_id: str, msg_ts: str) -> str:
        return f"{channel_id}:{msg_ts}"

    def _try_acquire_meeting_action_lock(self, key: str) -> bool:
        import time as _t
        now = _t.monotonic()
        exp = self._meeting_action_locks.get(key, 0.0)
        if exp > now:
            return False
        self._meeting_action_locks[key] = now + 8.0
        return True

    async def _dispatch_meeting_prompt(self, meeting: dict, text: str) -> None:
        # Empty thread_id (None) makes the gateway post to the channel root (no
        # thread). In a dedicated meeting channel the meeting IS the channel
        # conversation, so we reuse the channel session.
        source = self.build_source(
            chat_id=meeting["channel_id"],
            chat_type="group",
            user_id=meeting["user_id"],
            thread_id=(meeting.get("session_thread_id") or None),
        )
        # Meeting prompts (start/continue/next/end) are conversation messages to
        # the moderator agent. Even if a prompt starts with "/meeting ...", the
        # gateway would treat a COMMAND as an "unrecognized command", so always
        # send as TEXT.
        event = MessageEvent(
            text=text,
            message_type=MessageType.TEXT,
            source=source,
            raw_message={},
        )
        await self.handle_message(event)

    async def _meeting_participant_names(self) -> list:
        import json as _json
        import os as _os
        from pathlib import Path as _Path
        p = _Path(_os.environ.get("HERMES_HOME", str(_Path.home() / ".hermes"))) \
            / "hermes-slack-ext" / "meeting_participants.json"
        try:
            data = _json.loads(p.read_text(encoding="utf-8"))
            return [str(x) for x in data] if isinstance(data, list) else []
        except Exception:
            return []

    async def _refresh_meeting_room(self, body) -> None:
        from gateway.platforms.slack_meeting_room import build_meeting_room_blocks, load_store
        channel_id = (body.get("channel") or {}).get("id") or (body.get("container") or {}).get("channel_id", "")
        msg_ts = (body.get("container") or {}).get("message_ts", "")
        store = load_store()
        fallback, blocks = build_meeting_room_blocks(store, channel_id)
        if msg_ts:
            try:
                await self._get_client(channel_id).chat_update(channel=channel_id, ts=msg_ts, text=fallback, blocks=blocks)
            except Exception:
                pass

    async def _refresh_meeting_surface(self, body, meeting: dict) -> None:
        """Refresh the clicked message in place. If it is the in-channel control
        card (meeting.control_ts matches the clicked message ts), re-render the
        single-meeting card; otherwise (the ephemeral /meeting room) re-render the
        whole room. Both surfaces share the same action handler; only the refresh
        target differs."""
        from gateway.platforms.slack_meeting_room import (
            build_meeting_card_blocks, build_meeting_room_blocks, load_store)
        channel_id = (body.get("channel") or {}).get("id") or (body.get("container") or {}).get("channel_id", "")
        msg_ts = (body.get("container") or {}).get("message_ts", "")
        if not msg_ts:
            return
        if meeting.get("control_ts") and msg_ts == meeting.get("control_ts"):
            fallback, blocks = build_meeting_card_blocks(meeting)
        else:
            fallback, blocks = build_meeting_room_blocks(load_store(), channel_id)
        try:
            await self._get_client(channel_id).chat_update(
                channel=channel_id, ts=msg_ts, text=fallback, blocks=blocks)
        except Exception:
            pass

    async def _maybe_post_meeting_controls(self, chat_id: str) -> None:
        """After an agent response is sent to a channel that has a live meeting,
        (re)post the Meeting Controls card at the bottom so the buttons follow the
        conversation. Keeps exactly one card by deleting the previous one tracked
        via control_ts. Skipped when there is no live meeting (e.g. ended). Called
        from send() after the message chunks are posted; uses chat_postMessage
        directly (not send) so it does not recurse."""
        from gateway.platforms.slack_meeting_room import (
            load_store, save_store, get_meeting, list_meetings, build_meeting_card_blocks)
        store = load_store()
        live = [m for m in list_meetings(store, chat_id)
                if m.get("status") in ("setup", "review", "active")]
        if not live:
            return
        meeting = live[0]
        meeting["awaiting"] = False  # the moderator's reply just arrived; show controls again
        client = self._get_client(chat_id)
        old_ts = meeting.get("control_ts")
        if old_ts:
            try:
                await client.chat_delete(channel=chat_id, ts=old_ts)
            except Exception:
                pass
        try:
            fallback, blocks = build_meeting_card_blocks(meeting)
            # Post the card into the meeting thread (once anchored) so the controls
            # sit with the discussion, not split off at the channel root.
            posted = await client.chat_postMessage(
                channel=chat_id, text=fallback, blocks=blocks,
                thread_ts=(meeting.get("session_thread_id") or None))
            ts = posted.get("ts", "")
            if ts:
                store = load_store()
                m = get_meeting(store, meeting["id"])
                if m is not None:
                    m["control_ts"] = ts
                    m["awaiting"] = False
                    save_store(store)
        except Exception as exc:  # pragma: no cover - defensive
            logger.warning("[Slack] meeting controls repost failed: %s", exc)

    def _maybe_clean_meeting_message(self, chat_id: str, content: str) -> str:
        """Strip internal scaffolding ([MEETING] blocks, [PARALLEL-DONE]) and
        convert `@ProfileName` routing into real Slack mentions so participant and
        moderator bots actually get pinged (auto routing). Gated only on a mention
        map being present (a meeting install) — NOT on a local live meeting,
        because participant bots run in their own container and do not hold the
        meeting in their store; their hand-off `@Moderator` must still convert.
        clean_meeting_message is a no-op unless a known `@Name` or scaffolding is
        present, so running it on every send in a meeting install is safe. Called
        from send() before the agent's text is posted."""
        try:
            from gateway.platforms.slack_meeting_room import (
                load_mention_map, clean_meeting_message)
            mp = load_mention_map()
            if not mp:
                return content
            return clean_meeting_message(content, mp)
        except Exception:
            return content

    async def _maybe_speak_meeting_tts(self, chat_id: str, content: str, reply_to=None) -> str:
        """If the agent wrapped speakable text in [TTS]...[/TTS], synthesize it with
        THIS bot's configured TTS voice (tools.tts_tool reads tts.provider/voice
        from the bot's config), upload it as audio to the same thread (reply_to),
        and return the text with the [TTS] markers removed (the inner text stays
        visible). Gated only on a [TTS] marker being present — NOT on a local live
        meeting — because participant bots run in their own container and do not
        hold the meeting in their store; their spoken summary must still synthesize.
        No-op when there is no marker or synthesis fails."""
        try:
            import re as _re
            if "[TTS]" not in content:
                return content
            spoken = "\n".join(b.strip() for b in _re.findall(r"\[TTS\](.*?)\[/TTS\]", content, _re.DOTALL) if b.strip())
            cleaned = _re.sub(r"\n{3,}", "\n\n", _re.sub(r"\[/?TTS\]", "", content)).strip()
            if spoken:
                try:
                    import asyncio as _asyncio
                    import json as _json
                    from tools.tts_tool import text_to_speech_tool
                    loop = _asyncio.get_event_loop()
                    result = await loop.run_in_executor(None, text_to_speech_tool, spoken)
                    data = _json.loads(result) if isinstance(result, str) else (result or {})
                    path = data.get("file_path") or data.get("path")
                    if data.get("success") and path:
                        await self.send_voice(chat_id, path, reply_to=reply_to)
                except Exception as exc:  # pragma: no cover - defensive
                    logger.warning("[Slack] meeting TTS synth/upload failed: %s", exc)
            return cleaned
        except Exception:
            return content

    async def _post_meeting_note(self, meeting: dict, text: str) -> None:
        """Post an immediate acknowledgement note (button feedback) so the user
        gets a "clicked" signal before the async agent response arrives. Posts to
        the channel root when session_thread_id is empty."""
        ch = meeting.get("channel_id", "")
        thread = meeting.get("session_thread_id") or None
        try:
            await self._get_client(ch).chat_postMessage(channel=ch, thread_ts=thread, text=text)
        except Exception as exc:  # pragma: no cover - defensive
            logger.warning("[Slack] meeting note post failed: %s", exc)

    async def _handle_meeting_action(self, ack, body, action) -> None:
        await ack()
        from gateway.platforms.slack_meeting_room import (
            parse_action_value, get_meeting, set_status, set_session_thread,
            save_store, load_store, new_meeting_modal_view, continue_modal_view,
            build_start_prompt, build_approve_prompt, build_next_prompt,
            build_end_prompt, build_room_anchor_text,
        )
        action_id = action.get("action_id", "")
        trigger_id = body.get("trigger_id", "")
        channel_id = (body.get("channel") or {}).get("id", "")
        user_id = (body.get("user") or {}).get("id", "")

        if action_id == "hermes_meeting_new_open":
            names = await self._meeting_participant_names()
            try:
                await self._get_client(channel_id).views_open(
                    trigger_id=trigger_id, view=new_meeting_modal_view(channel_id, user_id, names))
            except Exception:
                pass
            return
        if action_id == "hermes_meeting_refresh":
            await self._refresh_meeting_room(body)
            return

        data = parse_action_value(action.get("value", ""))
        meeting_id = data.get("meeting_id", "")
        store = load_store()
        meeting = get_meeting(store, meeting_id)
        if not meeting:
            return
        kind = data.get("action", "")
        if kind == "continue":
            try:
                await self._get_client(channel_id).views_open(trigger_id=trigger_id, view=continue_modal_view(meeting_id))
            except Exception:
                pass
            return
        # State-changing + prompt-injecting (LLM-turn-consuming) actions guard
        # against double-click duplicates (same pattern as the board
        # _handle_board_action; the lock auto-expires after 8s).
        msg_ts = (body.get("container") or {}).get("message_ts", "")
        if not self._try_acquire_meeting_action_lock(
                self._meeting_action_lock_key(channel_id, msg_ts)):
            return
        if kind == "start":
            # The same Start button is status-aware: first press (setup) shows the
            # setup draft and moves to "review"; second press (review) is the
            # approval that starts routing and moves to "active". This prevents the
            # moderator from re-drafting (the earlier duplicate-draft bug).
            status = meeting.get("status", "setup")
            if status == "review":
                set_status(store, meeting_id, "active"); save_store(store)
                await self._post_meeting_note(meeting, ":white_check_mark: Approved — the moderator is kicking off the discussion. This can take up to a minute.")
                await self._dispatch_meeting_prompt(meeting, build_approve_prompt(meeting))
            else:
                # First press: anchor the meeting to a REAL channel message. Its ts
                # becomes the session thread, so the moderator's setup/routing, every
                # participant reply, the control card, notes, and the End summary all
                # live in one thread — and the button dispatches join that thread's
                # session (so End/Continue see the discussion).
                if not meeting.get("session_thread_id"):
                    try:
                        posted = await self._get_client(channel_id).chat_postMessage(
                            channel=channel_id, text=build_room_anchor_text(meeting))
                        anchor_ts = posted.get("ts", "")
                        if anchor_ts:
                            set_session_thread(store, meeting_id, anchor_ts); save_store(store)
                    except Exception as exc:  # pragma: no cover - defensive
                        logger.warning("[Slack] meeting anchor post failed: %s", exc)
                set_status(store, meeting_id, "review"); save_store(store)
                await self._post_meeting_note(meeting, ":arrow_forward: Starting — the moderator is drafting the setup. This can take up to a minute.")
                await self._dispatch_meeting_prompt(meeting, build_start_prompt(meeting))
            # Mark awaiting so the in-place card hides buttons until the reply lands;
            # the send() hook clears it and re-posts the card with buttons below the reply.
            meeting["awaiting"] = True; save_store(store)
            await self._refresh_meeting_surface(body, meeting)
            return
        if kind == "next":
            profile = data.get("profile", "")
            meeting["awaiting"] = True; save_store(store)
            await self._post_meeting_note(meeting, f":arrow_right: Next speaker: *{profile}*")
            await self._dispatch_meeting_prompt(meeting, build_next_prompt(meeting, profile))
            await self._refresh_meeting_surface(body, meeting)
            return
        if kind == "end":
            # Mark the meeting ended and refresh the card to its no-button "Ended"
            # state BEFORE dispatching the closing summary. The summary is produced
            # asynchronously and its send() hook (_maybe_post_meeting_controls)
            # re-posts the controls; that hook skips ended meetings, so the status
            # must already be "ended" when it fires. Otherwise the card reappears
            # with Continue/End buttons next to the closing summary — which reads as
            # a second End (the bug the user reported).
            set_status(store, meeting_id, "ended"); save_store(store)
            await self._post_meeting_note(meeting, ":stop_button: Ending the meeting.")
            await self._refresh_meeting_surface(body, meeting)
            await self._dispatch_meeting_prompt(meeting, build_end_prompt(meeting))
            return

    async def _handle_meeting_new_view(self, ack, body, view) -> None:
        await ack()
        import json as _json
        import time as _time
        from gateway.platforms.slack_meeting_room import (
            load_store, save_store, create_meeting, gen_meeting_id,
            parse_new_meeting_submission, build_meeting_card_blocks,
        )
        meta = _json.loads(view.get("private_metadata") or "{}")
        channel_id = meta.get("channel_id", "")
        fields = parse_new_meeting_submission(view.get("state", {}).get("values", {}))
        store = load_store()
        mid = gen_meeting_id(_time.time())
        mid, store = create_meeting(
            store, channel_id=channel_id, user_id=meta.get("user_id", ""),
            title=fields["title"], participants=fields["participants"], turns=fields["turns"],
            mode=fields["mode"], routing_mode=fields["routing_mode"],
            voice_mode=fields["voice_mode"], meeting_id=mid)
        save_store(store)
        # Creation only configures the meeting ("setup" status); it does NOT auto
        # start (drafting is triggered solely by the Start button — auto-dispatching
        # here would duplicate the draft on the Start click). Post the in-channel
        # Meeting Controls card so the user can act where the conversation flows
        # without re-typing a slash command, and store its ts (control_ts) so later
        # actions/responses can refresh or move that card.
        try:
            fallback, blocks = build_meeting_card_blocks(store["meetings"][mid])
            posted = await self._get_client(channel_id).chat_postMessage(
                channel=channel_id, text=fallback, blocks=blocks)
            ts = posted.get("ts", "")
            if ts:
                store = load_store()
                store["meetings"][mid]["control_ts"] = ts
                save_store(store)
        except Exception as exc:  # pragma: no cover - defensive
            logger.warning("[Slack] meeting controls card post failed: %s", exc)

    async def _handle_meeting_continue_view(self, ack, body, view) -> None:
        await ack()
        from gateway.platforms.slack_meeting_room import (
            load_store, get_meeting, build_continue_prompt,
        )
        meeting_id = view.get("private_metadata", "")
        values = view.get("state", {}).get("values", {})
        text = (values.get("msg", {}).get("v", {}) or {}).get("value", "").strip()
        store = load_store()
        meeting = get_meeting(store, meeting_id)
        if meeting and text:
            await self._post_meeting_note(meeting, f":pencil2: Continue: {text[:200]}")
            await self._dispatch_meeting_prompt(meeting, build_continue_prompt(meeting, text))
